<!-- Qiita風記事詳細：左サイドバー + 本文 の2カラムレイアウト -->
<div class="qiita-layout--article">

  <!-- 左サイドバー（いいね・アクション） -->
  <%= render "posts/article_sidebar", post: @post %>

  <!-- メイン：記事本文 -->
  <article>
    <!-- 戻るリンク -->
    <%= link_to "← タイムラインに戻る", posts_path,
        style: "font-size:13px;color:var(--qiita-text-secondary);text-decoration:none;display:inline-block;margin-bottom:16px;" %>

    <!-- 記事ヘッダー -->
    <div class="qiita-article-header">
      <!-- ステータス・タグ -->
      <div style="display:flex;gap:6px;margin-bottom:12px;flex-wrap:wrap;">
        <span class="qiita-tag">
          <%= t("enums.post.source_type_enum.#{@post.source_type_enum}") %>
        </span>
        <% if @post.status != "public_post" %>
          <span class="qiita-badge <%= @post.status == 'draft' ? 'qiita-badge--draft' : 'qiita-badge--private' %>">
            <%= t("enums.post.status.#{@post.status}") %>
          </span>
        <% end %>
      </div>

      <h1 class="qiita-article-header__title"><%= @post.title %></h1>

      <div class="qiita-article-header__meta">
        <div class="qiita-article-header__author">
          <div class="qiita-article-header__avatar">
            <%= @post.user.email[0].upcase %>
          </div>
          <div>
            <span style="font-size:14px;font-weight:700;color:var(--qiita-text);">
              <%= @post.user.email %>
            </span>
            <br>
            <span style="font-size:12px;color:var(--qiita-text-secondary);">
              投稿日: <%= l @post.created_at, format: :long %>
            </span>
          </div>
        </div>
      </div>
    </div>

    <!-- ソースプレビュー (Turbo Stream対応) -->
    <%= turbo_stream_from "post_#{@post.id}" %>

    <% if @post.source %>
      <div id="source_preview_<%= @post.id %>" style="margin-bottom:24px;">
        <% if @post.web_page? %>
          <%= render "posts/web_preview", metadata: @post.source %>
        <% elsif @post.book? %>
          <%= render "posts/book_preview", metadata: @post.source %>
        <% end %>
      </div>
    <% end %>

    <!-- 記事本文 -->
    <div class="qiita-prose">
      <%= simple_format @post.content %>
    </div>
  </article>
</div>
