<%= form_with(model: post, class: "space-y-5", data: { controller: "post-form" }) do |f| %>

  <% if post.errors.any? %>
    <div class="qiita-form-error">
      入力内容にエラーがあります。修正してから再送信してください。
    </div>
  <% end %>

  <!-- 公開設定 & ソースタイプ -->
  <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;">
    <div class="qiita-form-row" style="margin-bottom:0;">
      <label class="qiita-form-label"><%= f.label :status, "公開設定" %></label>
      <%= f.select :status,
          Post.statuses.keys.map { |k| [I18n.t("enums.post.status.#{k}"), k] },
          {},
          class: "qiita-form-select" %>
    </div>

    <div class="qiita-form-row" style="margin-bottom:0;">
      <label class="qiita-form-label">ソースタイプ</label>
      <%= f.select :source_type_enum,
          Post.source_type_enums.keys.map { |k| [t("enums.post.source_type_enum.#{k}"), k] },
          {},
          class: "qiita-form-select",
          data: { "post-form-target": "sourceType", action: "change->post-form#toggleFields" } %>
    </div>
  </div>

  <!-- Web URL フィールド -->
  <div data-post-form-target="webFields" class="<%= post.web_page? ? '' : 'hidden' %> qiita-form-section">
    <label class="qiita-form-label">WebページのURL</label>
    <%= text_field_tag "post[source_attributes][url]",
        (post.source.url if post.web_page? && post.source),
        class: "qiita-form-input",
        placeholder: "https://example.com" %>
    <p class="qiita-form-hint">※ URLを入力すると、自動的にタイトルや画像を取得します。</p>
  </div>

  <!-- 書籍フィールド -->
  <div data-post-form-target="bookFields" class="<%= post.book? ? '' : 'hidden' %> qiita-form-section">
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
      <div>
        <label class="qiita-form-label">書籍タイトル</label>
        <%= text_field_tag "post[source_attributes][title]",
            (post.source.title if post.book? && post.source),
            class: "qiita-form-input",
            placeholder: "書籍名を入力" %>
      </div>
      <div>
        <label class="qiita-form-label">著者名</label>
        <%= text_field_tag "post[source_attributes][author]",
            (post.source.author if post.book? && post.source),
            class: "qiita-form-input",
            placeholder: "著者名を入力" %>
      </div>
    </div>
  </div>

  <!-- タイトル -->
  <div class="qiita-form-row">
    <label class="qiita-form-label">タイトル <span style="color:#DC3545;">*</span></label>
    <%= f.text_field :title,
        class: "qiita-form-input",
        placeholder: "投稿のタイトルを入力してください",
        style: "font-size:16px;font-weight:700;" %>
  </div>

  <!-- 本文 -->
  <div class="qiita-form-row">
    <label class="qiita-form-label">学びのメモ・アウトプット <span style="color:#DC3545;">*</span></label>
    <%= f.text_area :content,
        class: "qiita-form-textarea",
        rows: 10,
        placeholder: "何を学び、どう感じましたか？" %>
  </div>

  <!-- 送信 -->
  <div style="display:flex;align-items:center;justify-content:flex-end;gap:12px;padding-top:16px;border-top:1px solid var(--qiita-border);">
    <%= link_to "キャンセル", posts_path,
        style: "font-size:14px;color:var(--qiita-text-secondary);text-decoration:none;" %>
    <%= f.submit "保存する", class: "qiita-btn qiita-btn--primary", style: "font-size:14px;padding:9px 24px;" %>
  </div>
<% end %>
