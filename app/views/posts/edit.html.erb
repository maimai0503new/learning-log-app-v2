<div class="qiita-form-page">
  <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:24px;padding-bottom:16px;border-bottom:1px solid var(--qiita-border);">
    <h1 style="font-size:22px;font-weight:700;margin:0;">投稿を編集</h1>
    <div style="display:flex;gap:8px;">
      <%= link_to "詳細に戻る", post_path(@post), class: "qiita-btn qiita-btn--ghost" %>
    </div>
  </div>

  <div class="qiita-card">
    <%= render "posts/form", post: @post %>
  </div>
</div>
