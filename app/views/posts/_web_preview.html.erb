<div id="web_preview_<%= metadata.id %>" class="mt-4 border rounded-xl overflow-hidden bg-base-200">
  <% if metadata.title.present? %>
    <div class="flex flex-col md:flex-row">
      <% if metadata.image_url.present? %>
        <div class="md:w-1/3">
          <img src="<%= metadata.image_url %>" alt="<%= metadata.title %>" class="h-full w-full object-cover">
        </div>
      <% end %>
      <div class="p-4 flex-1">
        <h3 class="font-bold text-lg line-clamp-2"><%= metadata.title %></h3>
        <p class="text-sm text-base-content/70 mt-1 line-clamp-3"><%= metadata.description %></p>
        <p class="text-xs text-primary mt-2 truncate"><%= metadata.url %></p>
      </div>
    </div>
  <% else %>
    <div class="p-8 text-center">
      <span class="loading loading-spinner loading-md"></span>
      <p class="text-sm mt-2 text-base-content/60">プレビューを取得中...</p>
    </div>
  <% end %>
</div>
