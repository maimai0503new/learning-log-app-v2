<div id="web_preview_<%= metadata.id %>">
  <% if metadata.title.present? %>
    <div class="qiita-link-preview">
      <% if metadata.image_url.present? %>
        <div class="qiita-link-preview__image">
          <img src="<%= metadata.image_url %>" alt="<%= metadata.title %>">
        </div>
      <% end %>
      <div class="qiita-link-preview__body">
        <p class="qiita-link-preview__title"><%= metadata.title %></p>
        <% if metadata.description.present? %>
          <p class="qiita-link-preview__desc"><%= metadata.description %></p>
        <% end %>
        <span class="qiita-link-preview__url">
          <svg width="12" height="12" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"/>
          </svg>
          <%= metadata.url %>
        </span>
      </div>
    </div>
  <% else %>
    <div class="qiita-link-preview qiita-link-preview--loading">
      <span style="display:inline-block;width:18px;height:18px;border:2px solid var(--qiita-border);border-top-color:var(--qiita-green);border-radius:50%;animation:spin 0.8s linear infinite;"></span>
      <span>プレビューを取得中...</span>
    </div>
    <style>@keyframes spin { to { transform: rotate(360deg); } }</style>
  <% end %>
</div>
