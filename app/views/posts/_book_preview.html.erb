<div id="book_preview_<%= metadata.id %>" class="qiita-book-preview">
  <div class="qiita-book-preview__icon">
    <svg width="22" height="22" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
        d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/>
    </svg>
  </div>
  <div class="qiita-book-preview__info">
    <span class="qiita-book-preview__badge">書籍</span>
    <p class="qiita-book-preview__title"><%= metadata.title %></p>
    <p class="qiita-book-preview__author"><%= metadata.author.presence || '著者不明' %></p>
    <% if metadata.ndc_label.present? %>
      <p class="qiita-book-preview__category">カテゴリ: <%= metadata.ndc_label %></p>
    <% end %>
  </div>
</div>
