<%# 左サイドバーコンポーネント（いいね・編集・削除アクション） %>
<aside class="qiita-article-sidebar">
  <%= render "posts/like_button", post: post %>

  <% if post.user == current_user %>
    <%= link_to edit_post_path(post), class: "qiita-btn qiita-btn--ghost",
        style: "display:flex;flex-direction:column;align-items:center;gap:2px;padding:8px;border-radius:50%;border:1px solid var(--qiita-border);font-size:11px;" do %>
      <svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
          d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
      </svg>
      編集
    <% end %>

    <%= button_to post, method: :delete,
        class: "qiita-btn qiita-btn--ghost",
        style: "display:flex;flex-direction:column;align-items:center;gap:2px;padding:8px;border-radius:50%;border:1px solid #F5C6CB;color:#DC3545;font-size:11px;background:none;cursor:pointer;",
        data: { turbo_confirm: "本当に削除しますか？" } do %>
      <svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
          d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
      </svg>
      削除
    <% end %>
  <% end %>
</aside>
