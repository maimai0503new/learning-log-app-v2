<div class="qiita-container">
  <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:20px;">
    <h1 style="font-size:20px;font-weight:700;margin:0;">タイムライン</h1>
    <%= link_to "新しい学びを記録する", new_post_path, class: "qiita-btn qiita-btn--primary" %>
  </div>

  <div style="max-width:760px;">
    <% @posts.each do |post| %>
      <div class="qiita-article-card">
        <div class="qiita-article-card__author">
          <div class="qiita-article-card__avatar">
            <%= post.user.email[0].upcase %>
          </div>
          <span class="qiita-article-card__username">
            <%= post.user.email %>
          </span>
          <span class="qiita-article-card__date">
            <%= time_ago_in_words(post.created_at) %>前
          </span>
        </div>

        <h2 class="qiita-article-card__title">
          <%= link_to post.title, post_path(post) %>
        </h2>

        <p class="qiita-article-card__excerpt">
          <%= markdown_to_plain_text(post.content) %>
        </p>

        <% if post.source %>
          <div style="background:#F9FAFB;border:1px solid var(--qiita-border);border-radius:4px;padding:10px 14px;margin-bottom:12px;">
            <p style="font-size:13px;font-weight:700;margin:0 0 2px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">
              <%= post.source.title.presence || post.source.url %>
            </p>
            <% if post.book? %>
              <p style="font-size:12px;color:var(--qiita-text-secondary);margin:0;">
                著者: <%= post.source.author.presence || '著者不明' %>
              </p>
            <% else %>
              <p style="font-size:12px;color:var(--qiita-text-secondary);margin:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">
                <%= post.source.url %>
              </p>
            <% end %>
          </div>
        <% end %>

        <div class="qiita-article-card__footer">
          <span class="qiita-tag">
            <%= t("enums.post.source_type_enum.#{post.source_type_enum}") %>
          </span>
          <%= render "posts/like_button", post: post %>
        </div>
      </div>
    <% end %>

    <% if @posts.empty? %>
      <div class="qiita-card" style="text-align:center;padding:48px;color:var(--qiita-text-secondary);">
        <p style="margin:0 0 16px;font-size:15px;">まだ投稿がありません</p>
        <%= link_to "最初の学びを投稿する", new_post_path, class: "qiita-btn qiita-btn--primary" %>
      </div>
    <% end %>
  </div>
</div>
