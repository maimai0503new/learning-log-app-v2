<%= turbo_frame_tag dom_id(post, :like_button) do %>
  <% if current_user&.likes&.exists?(post: post) %>
    <%= button_to post_like_path(post, current_user.likes.find_by(post: post)), method: :delete, class: "flex items-center text-red-500 hover:text-red-600 transition" do %>
      <svg class="h-5 w-5 fill-current" viewBox="0 0 20 20">
        <path d="M3.172 5.172a4 4 0 015.657 0L10 6.343l1.172-1.171a4 4 0 115.657 5.657L10 17.657l-6.828-6.829a4 4 0 010-5.656z" />
      </svg>
      <span class="ml-1 text-xs font-bold"><%= post.likes.count %></span>
    <% end %>
  <% else %>
    <%= button_to post_likes_path(post), method: :post, class: "flex items-center text-gray-400 hover:text-red-500 transition" do %>
      <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
      </svg>
      <span class="ml-1 text-xs font-bold"><%= post.likes.count %></span>
    <% end %>
  <% end %>
<% end %>
