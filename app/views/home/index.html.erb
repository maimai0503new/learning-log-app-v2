<div class="text-center">
  <h1 class="text-5xl font-bold mb-4 text-primary">Rails 8 + Tailwind + daisyUI</h1>
  <p class="py-6 text-xl">
    認証機能（Devise）と日本語化（i18n）の設定が完了しました。
  </p>
  
  <!-- Hotwire / Stimulus 確認用セクション -->
  <div class="mt-8 p-6 bg-base-200 rounded-box border border-base-300" data-controller="hello">
    <h2 class="text-2xl font-semibold mb-4">Hotwire (Stimulus) 動作確認</h2>
    <div class="flex flex-col items-center gap-4">
      <input type="text" data-hello-target="name" placeholder="お名前を入力してください" class="input input-bordered w-full max-w-xs">
      <button class="btn btn-secondary" data-action="click->hello#greet">
        挨拶を表示
      </button>
      <p class="text-lg font-medium text-secondary" data-hello-target="output"></p>
    </div>
  </div>

  <div class="mt-12">
    <% if user_signed_in? %>
      <div class="stats shadow bg-primary text-primary-content">
        <div class="stat">
          <div class="stat-title">現在のユーザー</div>
          <div class="stat-value text-2xl"><%= current_user.email %></div>
          <div class="stat-desc font-bold text-secondary">ログイン中</div>
        </div>
      </div>
    <% else %>
      <div class="flex flex-col gap-4">
        <p class="text-gray-500 italic">動作確認のためにログインまたは新規登録を行ってください。</p>
        <div class="flex justify-center gap-2">
          <%= link_to "ログイン", new_user_session_path, class: "btn btn-outline btn-secondary" %>
          <%= link_to "新規登録", new_user_registration_path, class: "btn btn-primary" %>
        </div>
      </div>
    <% end %>
  </div>
</div>
