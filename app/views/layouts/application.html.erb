<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Learning Log App V3" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Learning Log App V3">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-base-200 min-h-screen">
    <header class="navbar bg-base-100 shadow-sm mb-8">
      <div class="flex-1">
        <a href="/" class="btn btn-ghost text-xl">Learning Log</a>
      </div>
      <div class="flex-none">
        <ul class="menu menu-horizontal px-1">
          <% if user_signed_in? %>
            <li><%= link_to "プロフィール", edit_user_registration_path %></li>
            <li><%= button_to "ログアウト", destroy_user_session_path, method: :delete, class: "text-error" %></li>
          <% else %>
            <li><%= link_to "新規登録", new_user_registration_path %></li>
            <li><%= link_to "ログイン", new_user_session_path %></li>
          <% end %>
        </ul>
      </div>
    </header>

    <main class="container mx-auto px-4 max-w-4xl">
      <% if notice %>
        <div class="alert alert-success mb-4 shadow-lg">
          <svg xmlns="http://www.w3.org/2000/svg" class="stroke-current shrink-0 h-6 w-6" fill="none" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
          <span><%= notice %></span>
        </div>
      <% end %>

      <% if alert %>
        <div class="alert alert-error mb-4 shadow-lg">
          <svg xmlns="http://www.w3.org/2000/svg" class="stroke-current shrink-0 h-6 w-6" fill="none" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
          <span><%= alert %></span>
        </div>
      <% end %>

      <div class="card bg-base-100 shadow-xl p-8">
        <%= yield %>
      </div>
    </main>
  </body>
</html>
